#!/bin/sh

[ -n "$LKP_SRC" ] ||
export LKP_SRC="$(dirname "$(dirname "$(readlink -e -v "$0")")")"

show_help()
{
	cat <<EOF
Usage: lkp <command> [options]
$(cat $LKP_SRC/doc/command-index/* 2>/dev/null)

More commands can be found in ${LKP_SRC}/{bin,sbin,tools,lkp-exec}/
EOF
	echo ""
	echo "LKP-EXEC COMMANDS:"
	for cmd in "$LKP_SRC/lkp-exec/"*; do
		[ -x "$cmd" ] && [ -f "$cmd" ] || continue
		cmd_name="${cmd##*/}"
		usage=$(grep -E -m 1 -i "Usage:.*|opts\.banner.*" "$cmd" | sed -E -e 's/^[[:space:]]*//' -e 's/^(echo|opts\.banner[[:space:]]*=)?//' -e 's/^[[:space:]]*["'\'']//' -e 's/["'\''][[:space:]]*(1>&2)?.*$//' -e 's/^[[:space:]]*//' )
		if [ -n "$usage" ] && [ "$usage" != "Usage:" ]; then
			printf "\t%-20s %s\n" "$cmd_name" "$usage"
		else
			printf "\t%-20s\n" "$cmd_name"
		fi
	done
}

if [ $# = 0 ] || [ "$1" = 'help' ] || [ "$1" = '--help' ] || [ "$1" = '-h' ]; then
	show_help
	exit
fi

lkp_command="$1"
lkp_args=
shift

if [ "$lkp_command" = 'help' ]; then
	lkp_command="$1"
	lkp_args='--help'
	shift
fi

case "$lkp_command" in
	'install')	lkp_command='install'		;;
	'split')	lkp_command='split-job'		;;
	'compile')	lkp_command='job2sh'		;;
	'merge')	lkp_command='merge-remote-result'		;;
	'run-monitor')	lkp_command='run-local-monitor.sh'		;;
	'stop-monitor')	TMP=/tmp/lkp $LKP_SRC/bin/event/wakeup default-monitors; exit $?	;;
        'monitor'|'setup'|'test'|'daemon')
                exec "$LKP_SRC/bin/lkp-programs" "$lkp_command" "$@"
                ;;
	'path'|'depends')
		exec "$LKP_SRC/bin/lkp-programs" "$lkp_command" "$@"
		;;
	'run')
		if echo "$*" | grep '\.sh$' >/dev/null; then
			lkp_command='run-local.sh'
		else
			lkp_command='run-local'
		fi ;;
esac

try_run()
{
	local subdir="$1"
	local path="$LKP_SRC/$subdir/$lkp_command"
	shift

	[ -x "$path" ] && exec "$path" $lkp_args "$@"
}

try_run2()
{
	local subdir="$1"
	local path="$(find "$LKP_SRC/$subdir" -name "$lkp_command" -print -quit | head -n 1)"
	shift

	[ -x "$path" ] && exec "$path" $lkp_args "$@"
}

try_run 'bin'		"$@"
try_run 'sbin'		"$@"
try_run 'tools'		"$@"
try_run 'lkp-exec'	"$@"
try_run2 'tools' "$@"

echo "Cannot find \"$lkp_command\" command under $LKP_SRC/{bin,sbin,tools,lkp-exec}/"
exit 1
