#!/bin/bash
# - testtime
# - class
# - nr_threads
# - test
# - method
# - mode
# - type
# - sched
# - advise
# - hdd_opts

. $LKP_SRC/lib/env.sh
. $LKP_SRC/lib/debug.sh
. $LKP_SRC/lib/reproduce-log.sh

mount_dev()
{
	local mnt=/mnt/stress-ng

	[[ $nr_partitions -ge 1 ]] || die "nr_partitions is less than 1"
	partition=${partitions%% *}

	[[ "$test" = "verity" ]] && {
		log_cmd umount $partition
		log_cmd mkfs.$fs -q -F -O verity $partition || die "fail to mkfs.$fs -q -F -O verity $partition"
	}

	log_cmd mkdir -p $mnt
	log_cmd mount $partition $mnt 2>/dev/null

	# shellcheck disable=SC2164
	log_cmd cd $mnt

	stat -f $PWD
}

## some options are universal, put them in universal_setting
set_common_opts()
{
	[[ -n "$testtime" ]] || testtime=1

	common_opts="--timeout $testtime --times --verify --metrics --no-rand-seed"
}

# some classes need special setup
setup_class()
{
	## stressors spawn exec can't run as root
	## all classes need to exclud them except class exec_spawn
	exclude_opt="--exclude spawn,exec"

	# Fix stress-ng: error: [36360] process [36390] (stress-ng-swap) aborted early, out of system resources
	[[ "$(nproc)" -gt 16 ]] && exclude_opt="${exclude_opt},swap"

	case "$class" in
	"memory")
		stress_opts="--minimize"
		exclude_opt="${exclude_opt},stack"
		;;
	"os")
		stress_opts="--minimize"
		mount_dev
		;;
	"filesystem"|"interrupt"|"io")
		mount_dev
		;;
	"vm")
		# shellcheck disable=SC2164
		log_cmd cd ${mount_points%% *}
		;;
	*)
		;;
	esac
}

setup_test()
{
	[[ -n "$fs" ]] && {
		mount_dev || return
	}

	case "$test" in
	"swap")
		common_opts="${common_opts} --temp-path /mnt/stress-ng"
		;;
	"ping-sock")
		# Default: 1 0. Allow unprivileged ping sockets for threads to avoid EACCES
		log_cmd sysctl -w net.ipv4.ping_group_range="0 $nr_threads"
		;;
	"mq")
		# Default: queues_max=256, msg_max=10. Prevent POSIX message queue resource exhaustion
		log_cmd sysctl -w fs.mqueue.queues_max=2048
		log_cmd sysctl -w fs.mqueue.msg_max=2048
		;;
	"aio"|"aiol")
		# Default: 65536. Prevent io_setup failure with large numbers of async IO requests
		log_cmd sysctl -w fs.aio-max-nr=1048576
		[[ "$test" = "aiol" ]] && log_cmd sleep 2
		;;
	"inotify"|"dnotify")
		# Default: instances=128, watches=8192. Allow mass filesystem event watching
		log_cmd sysctl -w fs.inotify.max_user_instances=8192
		log_cmd sysctl -w fs.inotify.max_user_watches=524288
		;;
	"epoll"|"sock"|"sockmany"|"udp"|"udp-flood")
		# Default: 128 or 4096. Increase socket listen backlog queue size to prevent dropped connections
		log_cmd sysctl -w net.core.somaxconn=4096
		;;
	"sockpair")
		log_cmd sysctl -w net.core.somaxconn=4096
		common_opts="${common_opts} --oom-avoid"
		;;
	"bigheap"|"brk"|"loadavg"|"memthrash"|"mmaphuge"|"mmapcow"|"mmapmany")
		common_opts="${common_opts} --oom-avoid"
		;;
	"bad-ioctl"|"sysinval"|"cpu-online"|"mlockmany"|"oom-pipe"|"bind-mount"|"watchdog"|"smi")
		common_opts="${common_opts} --pathological"
		;;
	*)
		;;
	esac
}

setup_sysctl()
{
	# stress-ng: info: note: /proc/sys/kernel/sched_autogroup_enabled is 1 and this can impact scheduling throughput for processes not attached to a tty. Setting this to 0 may improve performance metrics
	[[ -w /proc/sys/kernel/sched_autogroup_enabled ]] && \
		log_cmd sysctl -w kernel.sched_autogroup_enabled=0
}

run_test()
{
	setup_sysctl
	set_common_opts

	if [[ -n "$test" ]]; then
		setup_test || die "setup test failed"

		if [[ -n "$method" ]]; then
			common_opts="${common_opts} --${test}-method $method"
		elif stress-ng --help 2>&1 | grep -E -q "^ +--${test}-method .*(\[.*all|all,)"; then
			# Dynamically check if this test supports an "all" method explicitly and appending it
			# This maximizes algorithmic coverage (e.g., testing all tree implementations, not just the default)
			common_opts="${common_opts} --${test}-method all"
		fi

		# Mapping x86 CI server regression parameters (mode, type, sched, advise)
		[[ -n "$mode" ]] && common_opts="${common_opts} --${test}-mode $mode"
		[[ -n "$type" ]] && common_opts="${common_opts} --${test}-type $type"
		[[ -n "$advise" ]] && common_opts="${common_opts} --madvise-advise $advise"
		[[ -n "$hdd_opts" ]] && common_opts="${common_opts} --hdd-opts $hdd_opts"

		if [[ -n "$sched" ]]; then
			if stress-ng --help 2>&1 | grep -q -E "\-\-${test}-sched"; then
				common_opts="${common_opts} --${test}-sched $sched"
			else
				# Fallback generic scheduling stress parameter
				common_opts="${common_opts} --workload-sched $sched"
			fi
		fi

		if [[ "$test" = "exec" ]] || [[ "$test" = "spawn" ]] || [[ "$test" = "bad-ioctl" ]]; then
			# these stressors need to be running without root privilege
			log_cmd mkdir /home/lkp
			log_cmd chown -R lkp:lkp /home/lkp
			log_cmd su - lkp -s /bin/bash -c "stress-ng $common_opts --$test $nr_threads 2>&1"
		else
			log_cmd stress-ng $common_opts --$test $nr_threads 2>&1
		fi
	else
		setup_class || die "setup class failed"

		log_cmd stress-ng $common_opts --sequential $nr_threads --class $class $stress_opts $exclude_opt 2>&1
	fi
}

has_cmd stress-ng || die "stress-ng is not installed"

run_test
