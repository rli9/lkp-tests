pkgname=cassandra
pkgver=5.0.5
pkgrel=0
pkgdesc="The Apache Cassandra database is the right choice when you need scalability and high availability without compromising performance."
arch=('i386' 'x86_64' 'aarch64')
url="http://cassandra.apache.org/"
license=(Apache)
# https://dlcdn.apache.org/cassandra/4.1.4/apache-cassandra-4.1.4-bin.tar.gz
source=(https://dlcdn.apache.org/cassandra/$pkgver/apache-$pkgname-$pkgver-bin.tar.gz)
md5sums=('SKIP')

. $LKP_SRC/lib/reproduce-log.sh
. $LKP_SRC/lib/tests/pkgbuild.sh

# No compile step; override the default build() (make_src_pkg from pkgbuild.sh)
# so install doesn't run make on the unbuilt source.
build()
{
	:
}

prepare()
{
	prepare_benchmark_path
    rename_versioned_src_pkg_dir apache-$pkgname-$pkgver
}

